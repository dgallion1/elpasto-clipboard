# .env.example — copy to .env and edit for your deployment.
# All values shown are safe placeholders.

# ===== Server =====
# Container always listens on 3000; map to a host port via DOCKER_PORT in the Makefile.
PORT=3000
# Set to "production" to enable HSTS and stricter CORS. Anything else = dev mode.
NODE_ENV=production
# Comma-separated list of origins allowed by CORS in production
# (NODE_ENV != "production" auto-allows http://localhost:3000).
CORS_ALLOWED_ORIGINS=

# ===== Storage =====
# Where the Go binary persists session metadata and snapshots.
DATA_DIR=/data
# Where the tunnel binaries the /api/downloads/* endpoint serves live. The
# Docker image bakes these into /downloads at build time; override only if
# you populate a different directory at runtime.
DOWNLOADS_DIR=/downloads

# Honor X-Forwarded-For / X-Real-IP. Only enable behind a trusted reverse proxy.
TRUST_PROXY_HEADERS=false

# ===== Session and clip limits =====
SESSION_EXPIRY_HOURS=24
# Bytes (legacy / reserved — current peer-only flow does not enforce these).
MAX_CLIP_BYTES=10485760
MAX_SESSION_BYTES=104857600
MAX_CLIPS_PER_ZONE=100
# Background cleanup interval in milliseconds.
CLEANUP_INTERVAL_MS=60000

# ===== Rate limiting =====
RATE_LIMIT_CREATE_PER_HOUR=20
RATE_LIMIT_BATCH_CREATE_PER_HOUR=60
RATE_LIMIT_LOOKUPS_PER_MINUTE=10
RATE_LIMIT_SIGNALS_PER_MINUTE=240
RATE_LIMIT_UPLOADS_PER_MINUTE=30
RATE_LIMIT_TUNNEL_AUTH_STARTS_PER_HOUR=10
RATE_LIMIT_TUNNEL_AUTH_CALLBACKS_PER_HOUR=30

# ===== Feature flags =====
ENABLE_BATCH_SESSION_CREATE=false

# ===== TURN (optional; required only for clients behind symmetric NAT) =====
# Long random hex; the same value is passed to coturn as --static-auth-secret.
# Generate via: openssl rand -hex 32
TURN_SECRET=
# Public TURN URI clients should connect to (e.g. turn:turn.example.com:3478).
TURN_SERVER=
# Used only when the `turn` Docker Compose profile is enabled. See deploy.local.mk.example.
# TURN_REALM=your-turn-domain.example
# TURN_EXTERNAL_IP=1.2.3.4

# ===== Tunnel auth (optional; required for server-relay tunnels) =====
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Long random hex.
TUNNEL_AUTH_SECRET=
# Comma-separated email allowlist.
TUNNEL_AUTH_ALLOWED_EMAILS=
# Comma-separated email-domain allowlist.
TUNNEL_AUTH_ALLOWED_DOMAINS=
# Public base URL of the elpasto server (used to build OAuth redirect URIs).
TUNNEL_BASE_URL=

# ===== Stats dashboard (optional) =====
# Long random hex. Callers without this key get HTTP 404 (not 401) on /api/stats.
STATS_DASHBOARD_KEY=

# ===== Frontend analytics (optional, both blank disables analytics) =====
# Cloudflare Web Analytics public token (build-time arg via Dockerfile).
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=
# Plausible: set both to the URLs returned by your Plausible instance, or leave blank.
PLAUSIBLE_SCRIPT_URL=
PLAUSIBLE_EVENT_URL=
NEXT_PUBLIC_PLAUSIBLE_ENABLED=

# ===== Dev / proxy config =====
# Go backend port for direct SSE connections in `npm run dev` to bypass Next.js
# proxy buffering. Production builds use embedded frontend, ignore this.
NEXT_PUBLIC_GO_BACKEND_PORT=8080
# Override the API base URL the frontend connects to (defaults to same-origin).
NEXT_PUBLIC_API_BASE_URL=
